# ============================================================================
# PharmaCRM — environment template.
# Local dev: copy to `.env` (defaults below match docker-compose).
# Production: set these in Render (API) and Vercel (web/admin) — never commit
# a filled-in .env (.env is gitignored). Each key says where to get its value.
# ============================================================================

# ---- Database ----
# Local: docker-compose default below.
# Prod: Neon (https://neon.tech → New Project → Connection string → POOLED).
#       Keep ?sslmode=require.
POSTGRES_URL=postgresql://pharmacrm:pharmacrm@localhost:5432/pharmacrm

# ---- Redis (BullMQ queue + monthly-cap counter) ----
# Local: docker-compose default below.
# Prod: Upstash (https://upstash.com → Redis → Create) — use the rediss:// (TLS)
#       URL. Free tier = 10k commands/day.
REDIS_URL=redis://localhost:6379

# ---- Auth secrets (generate two DIFFERENT values: `openssl rand -hex 32`) ----
JWT_SECRET=change-me
JWT_REFRESH_SECRET=change-me-too

# ---- CORS: deployed frontend origins (no trailing slash; comma-separated ok) ----
# Local defaults let web:3000 + admin:3002 call the API.
# Prod: set to your Vercel URLs after they deploy.
WEB_ORIGIN=http://localhost:3000
ADMIN_ORIGIN=http://localhost:3002

# ---- Frontend → API base URL (PUBLIC, not a secret) ----
# Local dev only; the production value is committed in apps/*/.env.production.
NEXT_PUBLIC_API_URL=http://localhost:3001/api/v1

# ---- Runtime knobs ----
# Render injects PORT + sets NODE_ENV=production automatically.
JOBS_DISABLED=          # "1" disables BullMQ workers (tests/one-off scripts)

# ---- WhatsApp Cloud API (Meta) — LEAVE BLANK to use MockProvider (zero cost) ----
# See build/checklists/external-setup.md. Fill only with real Meta credentials.
WA_TOKEN=               # permanent system-user access token
WA_PHONE_ID=            # phone number ID (Meta Business settings)
WA_APP_SECRET=          # verifies X-Hub-Signature-256 on webhook posts
WA_VERIFY_TOKEN=        # arbitrary string echoed in the webhook subscribe handshake

# ---- SMS gateway (Egyptian provider) — BLANK = MockProvider ----
SMS_API_KEY=

# ---- Optional analytics / error tracking (blank = disabled) ----
POSTHOG_KEY=            # https://posthog.com → Project Settings → API keys
POSTHOG_HOST=           # defaults to https://app.posthog.com when unset
SENTRY_DSN=
