# Committed on purpose: NEXT_PUBLIC_API_URL is a PUBLIC value (ships in client
# JS regardless) — not a secret. Next.js inlines it at `next build`.
# Points at the Render API. If your Render service name differs, change this
# host to https://<your-service>.onrender.com/api/v1 and redeploy.
NEXT_PUBLIC_API_URL=https://pharmacrm-api.onrender.com/api/v1
